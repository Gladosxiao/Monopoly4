# Playtest LLM 配置文件
# 复制为 .playtest.env 后填入真实密钥，.playtest.env 已被 git 忽略，不会提交。

# KIMI (Moonshot) API 密钥
PLAYTEST_LLM_API_KEY=sk-your-kimi-key-here

# KIMI OpenAI-compatible 端点
PLAYTEST_LLM_BASE_URL=https://api.moonshot.cn/v1

# 推荐模型：moonshot-v1-8k / moonshot-v1-32k / moonshot-v1-128k
PLAYTEST_LLM_MODEL=moonshot-v1-8k
