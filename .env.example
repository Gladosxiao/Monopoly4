# 大富翁4 Web 后端环境变量示例
# 复制为 .env 后按需修改，生产环境务必替换默认密钥。

# 服务端口
PORT=3000

# SQLite 数据库文件路径（相对或绝对路径均可）
DB_PATH=./data.sqlite

# JWT 密钥与令牌有效期
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_MS=604800000

# 允许的跨域来源（逗号分隔）；未配置时开发环境允许所有来源
ALLOWED_ORIGINS=http://localhost:5173

# 是否启用测试模式面板（仅房主可用，生产环境建议 false）
ENABLE_TEST_MODE=false

# 固定用户配置文件路径；不配置则使用内置默认账号
USERS_CONFIG_PATH=./users.json

# 前端构建产物路径（后端静态托管用）
# FRONTEND_DIST_PATH=../frontend/dist
